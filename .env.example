# Vendor Compliance Portal — Environment Configuration
# Copy to .env and fill in your values before running.

# ---------------------------------------------------------------
# Application
# ---------------------------------------------------------------
APP_NAME="Vendor Compliance Portal"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

# ---------------------------------------------------------------
# Logging
# ---------------------------------------------------------------
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ---------------------------------------------------------------
# Database  (MySQL 8 — matches docker-compose.yml defaults)
# ---------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=vendor_compliance
DB_USERNAME=vcpuser
DB_PASSWORD=secret

# ---------------------------------------------------------------
# Cache / Queue / Session
# ---------------------------------------------------------------
CACHE_STORE=database
QUEUE_CONNECTION=database
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# ---------------------------------------------------------------
# Mail  (use 'log' in development so emails go to laravel.log)
# ---------------------------------------------------------------
MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@vendor-compliance.test"
MAIL_FROM_NAME="${APP_NAME}"

# For production, switch to 'smtp' and fill in:
# MAIL_HOST=smtp.example.com
# MAIL_PORT=587
# MAIL_USERNAME=
# MAIL_PASSWORD=
# MAIL_ENCRYPTION=tls

# ---------------------------------------------------------------
# File storage  (private disk for vendor documents — NEVER public)
# ---------------------------------------------------------------
FILESYSTEM_DISK=local
# The 'vendor_documents' disk is configured in config/filesystems.php
# and stores all uploaded vendor files in storage/app/private/vendor-documents.
# Files are served only through authenticated controller actions.

# Maximum document upload size in kilobytes (default 10 MB)
DOCUMENT_MAX_UPLOAD_SIZE_KB=10240

# Allowed MIME type extensions for documents (per-document-type limits
# are set in the document_types table; this is the global fallback)
DOCUMENT_ALLOWED_MIME_TYPES=pdf,jpg,jpeg,png

# ---------------------------------------------------------------
# Compliance engine thresholds
# ---------------------------------------------------------------
# Documents expiring within this many days will trigger an early warning
COMPLIANCE_EXPIRY_EARLY_WARNING_DAYS=60

# Second notification threshold (reminder)
COMPLIANCE_EXPIRY_REMINDER_DAYS=30

# Urgent notification threshold (shown in red on dashboard)
COMPLIANCE_EXPIRY_URGENT_DAYS=7

# ---------------------------------------------------------------
# AWS (only needed if switching to S3 for file storage)
# ---------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-southeast-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ---------------------------------------------------------------
# Vite (asset bundler)
# ---------------------------------------------------------------
VITE_APP_NAME="${APP_NAME}"
